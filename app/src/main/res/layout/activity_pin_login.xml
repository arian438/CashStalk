<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/white">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="60dp"
        android:src="@drawable/ic_fingerprint"
        android:tint="@color/primaryColor"
        android:background="@drawable/circle_background"
        android:padding="20dp"/>

    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="user@example.com"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:ellipsize="middle"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="10dp"
        android:text="@string/enter_pin"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"/>

    <!-- Поля для ввода PIN (с точками) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal">

        <EditText
            android:id="@+id/pinDigit1"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/pinDigit2"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/pinDigit3"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/pinDigit4"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text=""
        android:textColor="@color/red"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <TextView
        android:id="@+id/btnLoginWithPassword"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="@string/login_with_password"
        android:textColor="@color/primaryColor"
        android:textSize="16sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="?attr/selectableItemBackground"/>
</LinearLayout>