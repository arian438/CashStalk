<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/white">

    <ImageView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/ic_lock"
        android:tint="@color/primaryColor"
        android:background="@drawable/circle_background"
        android:padding="20dp"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/create_pin"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:fontFamily="sans-serif-medium"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="20dp"
        android:text="@string/create_pin_description"
        android:textSize="16sp"
        android:textColor="@color/gray"
        android:gravity="center"
        android:lineSpacingExtra="4dp"/>

    <!-- Поля для ввода PIN (с точками) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:layout_gravity="center_horizontal">

        <EditText
            android:id="@+id/pinDigit1"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/pinDigit2"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/pinDigit3"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>

        <EditText
            android:id="@+id/pinDigit4"
            android:layout_width="70dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_input_pin_gray"
            android:gravity="center"
            android:inputType="numberPassword"
            android:maxLength="1"
            android:padding="0dp"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:password="true"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text=""
        android:textColor="@color/red"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="40dp"
        android:text="@string/continue_text"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/primaryColor"
        android:enabled="false"
        app:cornerRadius="12dp"
        style="@style/Widget.MaterialComponents.Button"/>

    <Button
        android:id="@+id/btnCancel"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="12dp"
        android:text="@string/cancel"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/light_gray"
        android:textColor="@color/black"
        app:cornerRadius="12dp"
        style="@style/Widget.MaterialComponents.Button"/>
</LinearLayout>