<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Хедер -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_header_rounded"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Иконка меню -->
                <ImageView
                    android:id="@+id/ic_menu_stats"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="8dp"
                    android:src="@drawable/ic_menu"
                    android:tint="@color/white" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/statistics"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <!-- Общие суммы -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/income"
                                android:textColor="#A0A0A0"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/totalIncomeValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₽"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/expense"
                                android:textColor="#A0A0A0"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/totalExpenseValue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 ₽"
                                android:textColor="@android:color/white"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Иконка колокольчика с бейджем -->
                <FrameLayout
                    android:id="@+id/bellContainer"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:id="@+id/ic_bell"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_bell"
                        android:tint="@color/white" />

                    <TextView
                        android:id="@+id/notificationBadge"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_notification_badge"
                        android:gravity="center"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        android:text="0" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Основной контент -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-12dp"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Переключатель периодов -->
            <TextView
                android:id="@+id/statsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/statistics_period_month"
                android:textColor="?attr/textColorPrimary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWeek"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/week"
                    android:textAllCaps="false"
                    app:checkedIcon="@null"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/month"
                    android:textAllCaps="false"
                    app:checkedIcon="@null"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/year"
                    android:textAllCaps="false"
                    app:checkedIcon="@null"
                    app:cornerRadius="18dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Переключатель типа статистики (общая / по категориям) -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/chartToggleGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBarChart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:checked="true"
                    android:text="@string/bar_chart"
                    android:textAllCaps="false"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPieChart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/pie_chart"
                    android:textAllCaps="false"
                    app:cornerRadius="18dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Контейнер для линейной диаграммы (месяцы) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/barChartCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="visible"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/cardBackgroundColor"
                app:strokeColor="?attr/cardStrokeColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/stats_income_expense_by_month"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:dividerPadding="6dp">

                        <include
                            android:id="@+id/rowJun"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            layout="@layout/view_bar_row" />

                        <include
                            android:id="@+id/rowJul"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            layout="@layout/view_bar_row" />

                        <include
                            android:id="@+id/rowAug"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            layout="@layout/view_bar_row" />

                        <include
                            android:id="@+id/rowSep"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            layout="@layout/view_bar_row" />

                        <include
                            android:id="@+id/rowOct"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            layout="@layout/view_bar_row" />

                        <include
                            android:id="@+id/rowNov"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            layout="@layout/view_bar_row" />
                    </LinearLayout>

                    <!-- Легенда -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="#0FB572" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="@string/income"
                                android:textColor="?attr/textColorSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="#EF4444" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:text="@string/expense"
                                android:textColor="?attr/textColorSecondary"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Контейнер для круговой диаграммы (по категориям) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/pieChartCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/cardBackgroundColor"
                app:strokeColor="?attr/cardStrokeColor"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Переключатель доходы/расходы для круговой диаграммы -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_input"
                        android:padding="4dp">

                        <TextView
                            android:id="@+id/btnPieExpenses"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:checked="true"
                            android:text="@string/expenses"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="14sp"
                            android:background="@drawable/bg_button" />

                        <TextView
                            android:id="@+id/btnPieIncomes"
                            android:layout_width="0dp"
                            android:layout_height="40dp"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/incomes"
                            android:textAllCaps="false"
                            android:textColor="?attr/textColorSecondary"
                            android:textSize="14sp"
                            android:background="@drawable/bg_input" />
                    </LinearLayout>

                    <!-- Подпись периода для круговой диаграммы -->
                    <TextView
                        android:id="@+id/piePeriodSubtitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="4dp"
                        android:textColor="?attr/textColorSecondary"
                        android:textSize="14sp"
                        android:gravity="center"
                        tools:text="Месяц • 1 мар - 31 мар" />

                    <!-- Контейнер для круговой диаграммы -->
                    <FrameLayout
                        android:id="@+id/pieChartContainer"
                        android:layout_width="match_parent"
                        android:layout_height="250dp"
                        android:layout_marginTop="16dp"
                        android:background="?attr/cardBackgroundColor">

                        <!-- Кастомная View для круговой диаграммы -->
                        <com.example.myfin.PieChartView
                            android:id="@+id/pieChartView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </FrameLayout>

                    <!-- Список категорий с процентами -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="8dp"
                        android:text="@string/categories"
                        android:textColor="?attr/textColorPrimary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/categoriesStatsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <!-- Пустое состояние для круговой диаграммы -->
                    <TextView
                        android:id="@+id/emptyPieChartText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center"
                        android:padding="20dp"
                        android:text="@string/no_data_for_period"
                        android:textColor="?attr/textColorSecondary"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>